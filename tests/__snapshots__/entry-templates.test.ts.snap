      else { res.writeHead(statusOrUrl, { Location: url2 }); }
      res.end();
    },
    getHeaders: function() {
      var h = Object.assign({}, resHeaders);
      if (setCookieHeaders.length > 0) h["set-cookie"] = setCookieHeaders;
