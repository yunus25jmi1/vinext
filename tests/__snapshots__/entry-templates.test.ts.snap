  // The RSC flight protocol is text-based, so decoding to strings and embedding
  // as JSON strings is ~3x more compact than the byte-array format.
  async function pumpReader() {
    if (reading) return;
    reading = true;
    try {
      while (true) {
        const result = await reader.read();
        if (result.done) {
          done = true;
          break;
